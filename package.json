  "scripts": {
    "dev": "next dev --turbopack",
    "dev:e2e": "NEXT_DIST_DIR=.next-e2e NODE_ENV=test MONGODB_URI=mongodb://localhost:27017/invoice-app-test MONGODB_DB_NAME=invoice-app-test NEXT_PUBLIC_API_URL=http://localhost:4001/ NEXT_PUBLIC_WS_URL=ws://localhost:4001/graphql NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000 next dev --turbopack",
    "build:e2e": "NEXT_DIST_DIR=.next-e2e MONGODB_URI=mongodb://localhost:27017/invoice-app-test MONGODB_DB_NAME=invoice-app-test NEXT_PUBLIC_API_URL=http://localhost:4001/ NEXT_PUBLIC_WS_URL=ws://localhost:4001/graphql NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000 next build",
    "start:e2e": "NEXT_DIST_DIR=.next-e2e MONGODB_URI=mongodb://localhost:27017/invoice-app-test MONGODB_DB_NAME=invoice-app-test NEXT_PUBLIC_API_URL=http://localhost:4001/ NEXT_PUBLIC_WS_URL=ws://localhost:4001/graphql NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000 next start",
    "build": "next build",
    "build:check": "NEXT_DIST_DIR=.next-build next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:browser": "vitest run --config vitest.browser.config.js",
    "test:browser:ui": "vitest --ui --config vitest.browser.config.js",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed --workers=1",
    "e2e:ui": "playwright test --ui",
    "e2e:debug": "PWDEBUG=1 playwright test --headed --workers=1",
    "e2e:report": "playwright show-report",
    "e2e:trace": "playwright show-trace",
    "e2e:smoke": "playwright test e2e/smoke",
    "e2e:a11y": "playwright test --project=a11y",
    "e2e:codegen": "playwright codegen --browser=chromium http://localhost:3000",
    "e2e:install": "playwright install --with-deps",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
