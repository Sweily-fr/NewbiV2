# ============================================
# Newbi V2 — Environment Variables
# ============================================
# Copy this file to .env.local and fill in the values.
# Variables marked REQUIRED must be set for the app to start.
# Variables marked OPTIONAL have sensible defaults or enable optional features.
#
# NEVER commit real secrets to version control.

# ============================================
# Database
# ============================================

# MongoDB connection string (REQUIRED)
MONGODB_URI=mongodb://localhost:27017/newbi

# MongoDB database name override (OPTIONAL, defaults to URI database)
MONGODB_DB_NAME=

# ============================================
# Authentication & Security
# ============================================

# Better Auth secret for signing tokens (REQUIRED, 32+ chars)
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Better Auth server-side URL (REQUIRED in production)
BETTER_AUTH_URL=http://localhost:3000

# Better Auth client-side URL (REQUIRED, must match BETTER_AUTH_URL)
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# Shared secret for internal API calls between newbi-api and newbiv2 (REQUIRED)
# Used by PDF generation (Puppeteer), leads/notify, and other internal routes.
# Generate with: openssl rand -base64 64
INTERNAL_API_SECRET=

# Additional trusted origins for Better Auth CORS (OPTIONAL, comma-separated)
# Used for Vercel preview deployments, staging, ngrok, etc.
# Example: https://my-preview.vercel.app,https://staging.newbi.fr
ADDITIONAL_TRUSTED_ORIGINS=

# ============================================
# OAuth Providers
# ============================================

# Google OAuth (OPTIONAL — enables Google sign-in)
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth (OPTIONAL — enables GitHub sign-in)
# https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ============================================
# Stripe — Payments & Subscriptions
# ============================================

# Stripe secret key (REQUIRED for billing features)
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...

# Stripe webhook secret (REQUIRED for subscription events)
# https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# Plan price IDs — Freelance (REQUIRED for checkout)
STRIPE_FREELANCE_MONTHLY_PRICE_ID=price_...
STRIPE_FREELANCE_YEARLY_PRICE_ID=price_...

# Plan price IDs — PME (REQUIRED for checkout)
STRIPE_PME_MONTHLY_PRICE_ID=price_...
STRIPE_PME_YEARLY_PRICE_ID=price_...

# Plan price IDs — Entreprise (REQUIRED for checkout)
STRIPE_ENTREPRISE_MONTHLY_PRICE_ID=price_...
STRIPE_ENTREPRISE_YEARLY_PRICE_ID=price_...

# Legacy monthly price ID (OPTIONAL, used by older flows)
STRIPE_PRICE_ID_MONTH=price_...

# Seat addon price ID (REQUIRED for per-seat billing)
STRIPE_SEAT_PRICE_ID=price_...

# Coupon IDs (OPTIONAL)
STRIPE_FIRST_YEAR_DISCOUNT_COUPON_ID=
STRIPE_NEW_ORG_COUPON_ID=
NEXT_PUBLIC_STRIPE_NEW_ORG_COUPON_ID=

# ============================================
# Cloudflare R2 — File Storage (Signatures/Icons)
# ============================================

# Cloudflare account ID (REQUIRED for icon/signature upload)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=

# R2 credentials for file transfers (REQUIRED for file transfer feature)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_API_URL=

# Transfer bucket name (REQUIRED for file transfer feature)
TRANSFER_BUCKET=

# Social icons CDN (OPTIONAL)
NEXT_PUBLIC_ICONS_SOCIAL_URL=
NEXT_PUBLIC_ICONS_SOCIAL_BUCKET_NAME=

# ============================================
# Email — Resend
# ============================================

# Resend API key (REQUIRED for transactional emails)
# https://resend.com/api-keys
RESEND_API_KEY=re_...

# ============================================
# SMS — Twilio (OPTIONAL, for phone verification)
# ============================================

# https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ============================================
# Backend API URLs
# ============================================

# GraphQL API URL (REQUIRED)
NEXT_PUBLIC_API_URL=http://localhost:4000/
NEXT_PUBLIC_GRAPHQL_ENDPOINT=http://localhost:4000/graphql

# WebSocket URL for subscriptions (REQUIRED for real-time features)
NEXT_PUBLIC_WS_URL=ws://localhost:4000/graphql

# Public app URL (REQUIRED in production)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Legacy NextAuth URL (OPTIONAL, used by some internal fetch calls)
NEXTAUTH_URL=http://localhost:3000

# ============================================
# Cloudinary (OPTIONAL — image optimization)
# ============================================

NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=

# ============================================
# Cloudflare Turnstile — Bot Protection (OPTIONAL)
# ============================================

# https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# ============================================
# Meta CAPI — Conversion Tracking (OPTIONAL)
# ============================================

META_PIXEL_ID=
META_CAPI_TOKEN=

# ============================================
# PDF Generation — Puppeteer (OPTIONAL overrides)
# ============================================

# Path to Chrome/Chromium binary (OPTIONAL, auto-detected if not set)
CHROME_PATH=
PUPPETEER_EXECUTABLE_PATH=
