{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "packageManager": "npm",
  "testRunner": "vitest",
  "vitest": {
    "configFile": "vitest.stryker.config.js"
  },
  "reporters": ["progress", "html", "clear-text"],
  "mutate": [
    "src/utils/invoiceUtils.js",
    "src/utils/quoteUtils.js",
    "src/utils/creditNoteUtils.js",
    "src/utils/api-gouv.js",
    "src/utils/errorMessages.js",
    "src/utils/seo-data.js",
    "src/lib/auth-utils.js",
    "src/lib/permissions.js",
    "src/lib/plan-limits.js"
  ],
  "concurrency": 2,
  "timeoutMS": 60000,
  "ignorePatterns": [
    ".next",
    ".windsurf",
    "e2e",
    "playwright-report",
    "test-results",
    "public",
    ".vercel",
    ".turbo"
  ],
  "thresholds": { "high": 80, "low": 60, "break": 50 }
}
